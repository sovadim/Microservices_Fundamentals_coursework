  "schemaVersion": 39,
  "tags": ["jvm", "spring-boot"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "definition": "label_values(jvm_memory_used_bytes, job)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "job",
        "query": { "query": "label_values(jvm_memory_used_bytes, job)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "title": "JVM Metrics",
  "uid": "jvm-metrics"
}
