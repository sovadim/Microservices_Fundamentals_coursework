{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Heap Memory Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 20 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\", job=~\"$job\"}",
          "legendFormat": "{{job}} - {{id}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Heap Memory Max",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 20 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jvm_memory_max_bytes{area=\"heap\", job=~\"$job\"}",
          "legendFormat": "{{job}} - {{id}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "GC Pause Duration (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 20 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{job=~\"$job\"}[1m])",
          "legendFormat": "{{job}} - {{cause}} {{action}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "GC Pause Count (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "fillOpacity": 20 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_count{job=~\"$job\"}[1m])",
          "legendFormat": "{{job}} - {{cause}} {{action}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Live Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 20 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=~\"$job\"}",
          "legendFormat": "{{job}} - live",
          "refId": "A"
        },
        {
          "expr": "jvm_threads_daemon_threads{job=~\"$job\"}",
          "legendFormat": "{{job}} - daemon",
          "refId": "B"
        }
      ]
    },
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "fillOpacity": 20 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "process_cpu_usage{job=~\"$job\"}",
          "legendFormat": "{{job}} - process",
          "refId": "A"
        },
        {
          "expr": "system_cpu_usage{job=~\"$job\"}",
          "legendFormat": "{{job}} - system",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Classes Loaded",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jvm_classes_loaded_classes{job=~\"$job\"}",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Non-Heap Memory Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
