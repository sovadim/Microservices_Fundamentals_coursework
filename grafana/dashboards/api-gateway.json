        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"api-gateway\"}[5m])) by (le, uri))",
          "legendFormat": "p99 {{uri}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Rate (4xx + 5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 20 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"api-gateway\", status=~\"4..|5..\"}[5m])) by (status, uri)",
          "legendFormat": "{{status}} {{uri}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Percentage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"api-gateway\", status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"api-gateway\"}[5m]))",
          "legendFormat": "5xx error rate",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Average Response Time by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 20 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_sum{job=\"api-gateway\"}[5m]) / rate(http_server_requests_seconds_count{job=\"api-gateway\"}[5m])",
          "legendFormat": "{{method}} {{uri}}",
          "refId": "A"
        }
      ]
    }
  ],
